<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>College Fee Payment System</display-name>

    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Add Fee -->
    <servlet>
        <servlet-name>AddFee</servlet-name>
        <servlet-class>servlet.AddFeePaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddFee</servlet-name>
        <url-pattern>/addFee</url-pattern>
    </servlet-mapping>

    <!-- Update Fee -->
    <servlet>
        <servlet-name>UpdateFee</servlet-name>
        <servlet-class>servlet.UpdateFeePaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateFee</servlet-name>
        <url-pattern>/updateFee</url-pattern>
    </servlet-mapping>

    <!-- Delete Fee -->
    <servlet>
        <servlet-name>DeleteFee</servlet-name>
        <servlet-class>servlet.DeleteFeePaymentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteFee</servlet-name>
        <url-pattern>/deleteFee</url-pattern>
    </servlet-mapping>

    <!-- Display Fee -->
    <servlet>
        <servlet-name>DisplayFee</servlet-name>
        <servlet-class>servlet.DisplayFeePaymentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DisplayFee</servlet-name>
        <url-pattern>/DisplayFeePaymentsServlet</url-pattern>
    </servlet-mapping>

    <!-- Report Servlet -->
    <servlet>
        <servlet-name>Report</servlet-name>
        <servlet-class>servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Report</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>

    <!-- Report Criteria Servlet (optional) -->
    <servlet>
        <servlet-name>ReportCriteria</servlet-name>
        <servlet-class>servlet.ReportCriteriaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReportCriteria</servlet-name>
        <url-pattern>/ReportCriteriaServlet</url-pattern>
    </servlet-mapping>

</web-app>